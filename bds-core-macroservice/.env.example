# Neon PostgreSQL Connection Settings
SPRING_DATASOURCE_URL=jdbc:postgresql://<neon-hostname>/batdongsan_db?sslmode=require
SPRING_DATASOURCE_USERNAME=<neon-username>
SPRING_DATASOURCE_PASSWORD=<neon-password>

# Payway Integration (US-010, US-011, US-028)
PAYWAY_SERVICE_URL=https://api-sandbox.payway.com.vn
PAYWAY_API_KEY=your-payway-api-key
PAYWAY_MERCHANT_ID=your-merchant-id
PAYWAY_VERIFY_KEY=your-webhook-verify-key
PAYWAY_WEBHOOK_BASE_URL=https://your-public-api-url.com
PAYWAY_RETURN_URL=https://your-app.com/payment-completion

# Cloudinary Integration (US-008)
CLOUD_NAME=your-cloud-name
CLOUDINARY_API_KEY=your-api-key
CLOUDINARY_API_SECRET=your-api-secret

# Internal Security (US-028)
ENCRYPTION_KEY=your-32-char-encryption-key-!!!
