# ==============================================================================
# BatDongSan Platform Environment Variables Template
# Copy this file to '.env' and adjust the values before running 'docker compose up'
# ==============================================================================

# ------------------------------------------------------------------------------
# 1. Database Configurations
# ------------------------------------------------------------------------------
# PostgreSQL connection parameters (General)
POSTGRESQL_HOST=postgres
POSTGRESQL_EXTERNAL_PORT=5432
POSTGRESQL_USER=postgres
POSTGRESQL_PASSWORD=password

# PostgreSQL settings specific to Core Macroservice
SPRING_DATASOURCE_URL=jdbc:postgresql://postgres:5432/batdongsan_db
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=password

# PostgreSQL settings specific to Financial Service
DB_HOST=postgres
DB_PORT=5432
DB_NAME=bds-financial-service-db
DB_USERNAME=postgres
DB_PASSWORD=password

# MongoDB URI (Search and Moderation services)
MONGODB_URI=mongodb://mongodb:27017/bds

# ------------------------------------------------------------------------------
# 2. Infrastructure Services Discovery & Messaging
# ------------------------------------------------------------------------------
# Service Discovery (Eureka)
EUREKA_URI=http://eureka-server:8761/eureka/
EUREKA_HOSTNAME=eureka-server

# Message Broker (Kafka)
KAFKA_BOOTSTRAP_SERVERS=kafka:29092

# ------------------------------------------------------------------------------
# 3. Application Credentials & Secrets
# ------------------------------------------------------------------------------
# JWT / Token Cryptographic Signing Secrets
APP_SECRET=BatDongScamSecretKeyForJWTTokenAtLeast256BitsLong!!
JWT_SECRET=BatDongScamSecretKeyForJWTTokenAtLeast256BitsLong!!
ENCRYPTION_KEY=default-encryption-key-32-chars!!!

# Token Lifespans
APP_JWT_TOKEN_EXPIRES_IN=10800000
APP_JWT_REFRESH_TOKEN_EXPIRES_IN=86400000
JWT_EXPIRATION=10800000

# ------------------------------------------------------------------------------
# 4. Third-Party Integrations
# ------------------------------------------------------------------------------
# Cloudinary Storage
CLOUD_NAME=your-cloudinary-cloud-name
CLOUDINARY_API_KEY=your-cloudinary-api-key
CLOUDINARY_API_SECRET=your-cloudinary-api-secret

# PayWay Payment Gateway
PAYWAY_SERVICE_URL=http://localhost:3000
PAYWAY_API_KEY=default-key
PAYWAY_MERCHANT_ID=default-merchant
PAYWAY_VERIFY_KEY=default-verify-key
PAYWAY_WEBHOOK_BASE_URL=http://api-gateway:8080
PAYWAY_RETURN_URL=http://localhost:3000/return

# PayPal Integration
PAYPAL_CLIENT_ID=your-paypal-client-id
PAYPAL_CLIENT_SECRET=your-paypal-client-secret
PAYPAL_BASE_URL=https://api-m.sandbox.paypal.com
PAYPAL_RETURN_URL=http://financial-service:8086/api/payments/paypal/return
PAYPAL_CANCEL_URL=http://financial-service:8086/api/payments/paypal/cancel
PAYPAL_BRAND_NAME=BDS Platform

# Firebase / Push Notifications (Notification Service)
FIREBASE_ENABLED=false
FIREBASE_APP_NAME=bds-firebase
FIREBASE_CREDENTIALS_FILE=
FIREBASE_PROJECT_ID=
